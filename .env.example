# GitHub Scout AI - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# APPLICATION
# =============================================================================
APP_ENV=development
LOG_LEVEL=INFO
DATABASE_PATH=data/scout.db

# =============================================================================
# GITHUB
# =============================================================================
# Create at: GitHub Settings > Developer Settings > Personal Access Tokens
# Required scopes: public_repo (read-only access to public repos)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# TELEGRAM
# =============================================================================
# Create bot via @BotFather on Telegram
# 1. Message @BotFather
# 2. Send /newbot
# 3. Follow prompts to get your token
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Your Telegram user ID (send /start to @userinfobot to get it)
TELEGRAM_CHAT_ID=123456789

# Webhook URL (only needed for production/Railway deployment)
TELEGRAM_WEBHOOK_URL=https://your-app.railway.app/webhook

# =============================================================================
# AI PROVIDERS (Priority: DeepSeek > Qwen > OpenAI > Anthropic)
# =============================================================================
# PRIMARY - DeepSeek (cheapest, use for everything)
# Get at: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# SECONDARY - Qwen (backup if DeepSeek fails)
# Get at: https://dashscope.console.aliyun.com
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# FALLBACK - OpenAI (expensive, use only when cheap models fail)
# Get at: https://platform.openai.com
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# LAST RESORT - Anthropic (expensive, rarely needed)
# Get at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# SCHEDULER
# =============================================================================
# Cron expression for when to run daily digest (default: 8 AM UTC)
DIGEST_SCHEDULE=0 8 * * *

# How many times per day to run the scanner
RUN_FREQUENCY=2

# =============================================================================
# COST CONTROLS
# =============================================================================
# Maximum repos to analyze per run (keeps AI costs down)
MAX_REPOS_PER_RUN=5

# Maximum tokens per run (safety limit)
MAX_TOKENS_PER_RUN=50000

# Monthly budget in USD (alerts when approaching)
MONTHLY_BUDGET_USD=30

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable builder agent (Phase 5+)
ENABLE_BUILDER=false

# Enable learning system (Phase 7+)
ENABLE_LEARNING=false
